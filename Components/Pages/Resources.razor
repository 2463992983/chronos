@page "/resources"

<PageTitle>学习资源</PageTitle>

<article class="article-page">
  <header class="article-header">
    <h1>学习资源</h1>
    <p class="article-meta">官方文档、社区与工具推荐</p>
  </header>

  <section class="resource-section">
    <h2>官方资源</h2>
    <div class="resource-list">
      <a class="resource-link" href="https://godotengine.org" target="_blank" rel="noopener">
        <strong>Godot 官网</strong>
        <span>下载引擎、查看新闻与版本信息</span>
      </a>
      <a class="resource-link" href="https://docs.godotengine.org/zh-cn/" target="_blank" rel="noopener">
        <strong>官方中文文档</strong>
        <span>最权威的 API 参考与教程</span>
      </a>
      <a class="resource-link" href="https://github.com/godotengine/godot" target="_blank" rel="noopener">
        <strong>GitHub 仓库</strong>
        <span>源码、Issue 与贡献指南</span>
      </a>
    </div>
  </section>

  <section class="resource-section">
    <h2>社区</h2>
    <div class="resource-list">
      <a class="resource-link" href="https://www.reddit.com/r/godot/" target="_blank" rel="noopener">
        <strong>r/godot</strong>
        <span>Reddit 社区，作品分享与问答</span>
      </a>
      <a class="resource-link" href="https://godotengine.org/community" target="_blank" rel="noopener">
        <strong>官方社区页面</strong>
        <span>论坛、Discord、IRC 等</span>
      </a>
    </div>
  </section>

  <section class="resource-section">
    <h2>推荐插件与工具</h2>
    <div class="resource-list">
      <div class="resource-link static">
        <strong>Aseprite / LibreSprite</strong>
        <span>像素画绘制工具</span>
      </div>
      <div class="resource-link static">
        <strong>Tiled Map Editor</strong>
        <span>2D 瓦片地图编辑器，Godot 可直接导入</span>
      </div>
      <div class="resource-link static">
        <strong>Godot Asset Library</strong>
        <span>引擎内置资源库，免费脚本与素材</span>
      </div>
    </div>
  </section>
</article>
